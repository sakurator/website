{
	"name": "sakurator",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"start": "set NODE_ENV=production && node ./bin/www",
		"start-nodemon": "set NODE_ENV=development && nodemon --watch src --ext js,json,pug,sass ./bin/www",
		"compile-stylesheets": "sass --watch src/sass/app.sass public/stylesheets/app.css",
		"dev": "npm-run-all --parallel start-nodemon compile-stylesheets"
	},
	"dependencies": {
		"@prisma/adapter-mariadb": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"axios": "^0.26.1",
		"cookie-parser": "~1.4.4",
		"debug": "~2.6.9",
		"dotenv": "^16.3.1",
		"express": "~4.16.1",
		"http-errors": "~1.6.3",
		"jsonwebtoken": "^9.0.2",
		"morgan": "~1.9.1",
		"prisma": "^7.8.0",
		"pug": "^3.0.2",
		"tsx": "^4.22.0"
	},
	"devDependencies": {
		"@types/express": "^5.0.6",
		"nodemon": "^2.0.15",
		"npm-run-all": "^4.1.5",
		"sass": "^1.49.10"
	},
	"prisma": {
		"seed": "node prisma\\seed.js"
	}
}
