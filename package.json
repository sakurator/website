{
	"name": "sakurator",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "set NODE_ENV=production && node ./bin/www",
		"start-nodemon": "set NODE_ENV=development && nodemon --watch src --ext js,json,pug,sass ./bin/www",
		"compile-stylesheets": "sass --watch src/sass/app.sass public/stylesheets/app.css",
		"dev": "npx tsx ./build.ts"
	},
	"dependencies": {
		"@prisma/adapter-mariadb": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@sulfajs/sulfajs": "^1.1.0",
		"@tanstack/react-query": "^5.100.14",
		"axios": "^0.26.1",
		"clsx": "^2.1.1",
		"cookie-parser": "~1.4.4",
		"debug": "~2.6.9",
		"dotenv": "^16.3.1",
		"esbuild": "^0.28.0",
		"esbuild-plugin-alias": "^0.2.1",
		"esbuild-sass-plugin": "^3.7.0",
		"express": "~4.16.1",
		"http-errors": "~1.6.3",
		"js-cookie": "^3.0.7",
		"jsonwebtoken": "^9.0.2",
		"morgan": "~1.9.1",
		"nuqs": "^2.8.9",
		"prisma": "^7.8.0",
		"pug": "^3.0.2",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-router": "^7.15.1",
		"react-use": "^17.6.0",
		"tsx": "^4.22.0",
		"typescript": "^6.0.3",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@types/cookie-parser": "^1.4.10",
		"@types/debug": "^4.1.13",
		"@types/express": "^5.0.6",
		"@types/morgan": "^1.9.10",
		"@types/node": "^25.9.1",
		"@types/react-dom": "^19.2.3",
		"nodemon": "^2.0.15",
		"npm-run-all": "^4.1.5",
		"sass": "^1.49.10"
	},
	"prisma": {
		"seed": "node prisma\\seed.js"
	}
}
